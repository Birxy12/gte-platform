rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() { 
      // Checks if user has an admin role
      return isAuthenticated() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // --- Users ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // --- User Progress ---
    // Modified from your provided /user_progress/{userId} to /userProgress/{progressId}
    // to correctly match the progressService.js collection name and composite document IDs.
    // Also explicitly enabled `list` queries to prevent permission errors when querying by userId.
    match /userProgress/{progressId} {
      allow list: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow get, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- Quizzes ---
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();      // Anyone can read quizzes
      allow write: if isAdmin();             // Only admins can create or modify quizzes
    }

    // --- Certificates ---
    match /certificates/{userId} {
      allow read: if isOwner(userId);        // Users can read their own certificates
      allow create: if isAdmin();            // Only admins can create certificates (or auto-create based on quiz completion)
      allow update: if isOwner(userId);      // Users can update their certificates if needed
      allow delete: if isAdmin();            // Admins can delete certificates
    }

    // --- Social & App Settings ---
    match /friends/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /friendRequests/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /followers/{docId} {
      allow read, write: if isAuthenticated();
    }
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Presence ---
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Chats & Messages ---
    match /chats/{chatId} {
      // Simplified chat rules merged as requested
      allow read, write: if isAuthenticated();

      match /messages/{messageId} {
        allow read, write: if isAuthenticated();
      }

      match /typing/{userId} {
        allow read, write: if isAuthenticated();
      }

      match /reads/{messageId} {
        allow read, write: if isAuthenticated();
      }
    }

    // --- Content & LMS ---
    match /courses/{courseId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read: if true; // Public posts
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.authorEmail);
    }
    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- Analytics & Admin ---
    match /analytics/{docId} { allow read, write: if isAdmin(); }
    match /logs/{logId} { allow read: if isAdmin(); allow create: if isAuthenticated(); }
    
    // Explicitly updated notifications list queries so you do not receive permission errors
    match /notifications/{notificationId} {
      allow list: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow get, update, delete: if isOwner(resource.data.userId);
      allow create: if isAuthenticated();
    }
  }
}
