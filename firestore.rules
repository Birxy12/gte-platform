rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isAuthenticated() { return request.auth != null; }
    
    // Safer role checks
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isAdmin() { 
      return isAuthenticated() && (
        request.auth.token.admin == true || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin')
      ); 
    }
    
    function isInstructor() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        (getUserData().role == 'instructor' || getUserData().role == 'admin')
      );
    }
    
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // --- Users ---
    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coins']) && 
        (request.resource.data.coins == (resource.data.get('coins', 0) + 20))
      );
      allow delete: if isAdmin();
    }

    // --- Enrollments ---
    match /enrollments/{enrollmentId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isInstructor());
      allow delete: if isAdmin();
    }

    // --- Course Materials ---
    match /courseMaterials/{materialId} {
      allow read, list: if isAuthenticated() && (
        isInstructor() || 
        (resource.data.courseId != null && exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + "_" + resource.data.courseId)))
      );
      allow create, update, delete: if isInstructor();
    }

    // --- Quiz Results ---
    match /quizResults/{resultId} {
      allow read, list: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isInstructor()
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // --- User Progress ---
    match /userProgress/{progressId} {
      allow list: if isAuthenticated();
      allow get, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- Quizzes ---
    match /quizzes/{quizId} {
      allow read, list: if isAuthenticated();
      allow write: if isInstructor();  // Instructors & admins can manage quizzes
    }

    // --- Certificates ---
    match /certificates/{userId} {
      allow read, list: if isOwner(userId);
      allow create: if isAdmin();
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // --- Social & App Settings ---
    match /friends/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /friendRequests/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /followers/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /reports/{reportId} {
      allow read: if isInstructor();
      allow create: if isAuthenticated();
      allow update, delete: if isInstructor();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Presence ---
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Chats & Messages ---
    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId);
        
        allow update: if isAuthenticated() && (
          request.auth.uid == resource.data.senderId ||
          (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
        );
      }

      match /status/{userId} {
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }

      match /reads/{messageId} {
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- Content & LMS ---
    match /courses/{courseId} {
      allow read, list: if isAuthenticated();
      allow write: if isInstructor();  // Instructors & admins can manage courses
    }
    match /posts/{postId} {
      allow read, list: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.authorEmail);
    }
    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- Reels ---
    match /reels/{reelId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == (resource.data.userId));
    }

    // --- Missions ---
    match /missions/{missionId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Leadership ---
    match /leadership/{docId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // --- Notifications ---
    match /notifications/{notificationId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // --- Testimonials ---
    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isInstructor();  // Instructors & admins can moderate
    }
  }
}
