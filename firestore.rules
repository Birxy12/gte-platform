rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() { 
      // Checks if user has an admin role
      return isAuthenticated() && (
        request.auth.token.admin == true || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // --- Users ---
    match /users/{userId} {
      allow read, list: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // --- User Progress ---
    // Modified to correctly match progressService.js and prevent list errors
    match /userProgress/{progressId} {
      allow list: if isAuthenticated();
      allow get, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // --- Quizzes ---
    match /quizzes/{quizId} {
      allow read, list: if isAuthenticated();      // Anyone can read quizzes
      allow write: if isAdmin();             // Only admins can create or modify quizzes
    }

    // --- Certificates ---
    match /certificates/{userId} {
      allow read, list: if isOwner(userId);        // Users can read their own certificates
      allow create: if isAdmin();            // Only admins can create certificates
      allow update: if isOwner(userId);      // Users can update their certificates
      allow delete: if isAdmin();            // Admins can delete certificates
    }

    // --- Social & App Settings ---
    match /friends/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /friendRequests/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /followers/{docId} {
      allow read, list, write: if isAuthenticated();
    }
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Presence ---
    match /presence/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId) || isAdmin();
    }

    // --- Chats & Messages ---
    match /chats/{chatId} {
      // Only participants can read or update the group metadata
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow delete: if isAdmin();

      match /messages/{messageId} {
        // Only participants of the parent chat can read or send messages
        allow read, create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        
        allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.senderId);
        
        // Allow sender to update everything, or receiver to update only isRead
        allow update: if isAuthenticated() && (
          request.auth.uid == resource.data.senderId ||
          (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']))
        );
      }

      match /status/{userId} {
        // Only participants can see each other's typing/recording status
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }

      match /reads/{messageId} {
        // Track which user has read which message
        allow read, write: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // --- Content & LMS ---
    match /courses/{courseId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /posts/{postId} {
      allow read, list: if true; // Public posts
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Allow users to toggle likes/reactions
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.authorEmail);
    }
    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // --- Reels ---
    // Added during Phase 4 upgrades to support the new video platform
    match /reels/{reelId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // For likes/comments
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == (resource.data.userId));
    }

    // --- Tasks ---
    match /tasks/{taskId} {
      allow read, list: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- Leadership ---
    match /leadership/{docId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    // --- Notifications ---
    // Updated list queries to prevent permission errors
    match /notifications/{notificationId} {
      allow get, update, delete: if isOwner(resource.data.userId);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated();
    }

    // --- Testimonials ---
    match /testimonies/{testimonyId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }
  }
}
